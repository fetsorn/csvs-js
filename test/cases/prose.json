[
  {
    "name": "build without prose flag returns no @ keys",
    "op": "build",
    "initial": "prose_default",
    "query": ["query_prose_japan"],
    "prose": false,
    "expected": ["record_prose_japan_no_prose"]
  },
  {
    "name": "build with prose flag returns @ keys",
    "op": "build",
    "initial": "prose_default",
    "query": ["query_prose_japan"],
    "prose": true,
    "expected": ["record_prose_japan"]
  },
  {
    "name": "build with prose flag returns no @ keys when no blobs exist",
    "op": "build",
    "initial": "prose_default",
    "query": ["query_prose_japan"],
    "prose": true,
    "record": "record_prose_everest",
    "expected": ["record_prose_everest"]
  },
  {
    "name": "search by untagged prose content returns light records",
    "op": "select",
    "initial": "prose_default",
    "query": ["query_prose_search"],
    "expected": ["record_prose_japan_light"]
  },
  {
    "name": "search by language-tagged prose content returns light records",
    "op": "select",
    "initial": "prose_default",
    "query": ["query_prose_search_ru"],
    "expected": ["record_prose_japan_light"]
  },
  {
    "name": "insert with @ keys writes blob and strips @ from tablets",
    "op": "insert",
    "initial": "prose_default",
    "query": ["record_prose_insert"],
    "expected_blob": {
      "path": "prose/moved-to-bath.en",
      "content": "Relocated to Bath for work"
    }
  }
]
